{
  "name": "agent-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Local CLI harness for long-running Claude Agent SDK sessions (Planner -> Executor -> Evaluator).",
  "type": "module",
  "bin": {
    "harness": "./bin/harness"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && (cp -r src/prompts dist/prompts 2>/dev/null || true)",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node ./bin/harness"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "commander": "^12.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.17.30",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
